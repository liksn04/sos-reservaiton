create or replace function public.log_reservation_update()
returns trigger
language plpgsql
security definer
set search_path = public
as $$
begin
  if (
    old.date,
    old.start_time,
    old.end_time,
    old.is_next_day,
    old.team_name,
    old.people_count,
    old.purpose
  ) is distinct from (
    new.date,
    new.start_time,
    new.end_time,
    new.is_next_day,
    new.team_name,
    new.people_count,
