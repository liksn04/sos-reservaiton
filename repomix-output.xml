      if (fiscalYear) q = q.eq('fiscal_year', fiscalYear);
      if (fiscalHalf)  q = q.eq('fiscal_half', fiscalHalf);

      const { data, error } = await q;
      if (error) throw error;
      return data as BudgetTransaction[];
    },
  });
}
